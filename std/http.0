            } else if escaped == 98_u8 {
                decoded = 8_u8
            } else if escaped == 102_u8 {
                decoded = 12_u8
            } else if escaped == 110_u8 {
                decoded = 10_u8
            } else if escaped == 114_u8 {
                decoded = 13_u8
            } else if escaped == 116_u8 {
                decoded = 9_u8
            } else if escaped == 117_u8 {
                let unit: Maybe<u16> = __zero_std_json_hex_u16(value, input + 1)
