        } else if byte == 37_u8 {
            if input + 2 >= std.mem.len(text) {
                return null
            }
            let high: Maybe<u8> = std.ascii.hexValue(text[input + 1])
            let low: Maybe<u8> = std.ascii.hexValue(text[input + 2])
            if !high.has || !low.has {
                return null
