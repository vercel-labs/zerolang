        }
        if !unicode_written {
            if output >= std.mem.len(buffer) {
                return null
            }
            buffer[output] = decoded
            output = output + 1
        }
        input = input + 1
    }
    return buffer[..output]
}

fn __zero_std_json_string(buffer: MutSpan<u8>, bytes: Span<u8>, key: Span<u8>) -> Maybe<Span<u8>> {
