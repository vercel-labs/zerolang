            buffer[output] = 37_u8
            buffer[output + 1] = __zero_std_url_hex_char(byte / 16_u8)
            buffer[output + 2] = __zero_std_url_hex_char(byte % 16_u8)
            output = output + 3
        }
        input = input + 1
    }
    return buffer[..output]
}

fn __zero_std_url_query_unescape(buffer: MutSpan<u8>, text: Span<u8>) -> Maybe<Span<u8>> {
