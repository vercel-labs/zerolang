fn __zero_std_http_status_reason(status: u16) -> String {
    if status == 100_u16 {
        return "Continue"
    }
    if status == 200_u16 {
        return "OK"
    }
    if status == 201_u16 {
        return "Created"
    }
    if status == 202_u16 {
        return "Accepted"
    }
    if status == 204_u16 {
        return "No Content"
    }
    if status == 301_u16 {
        return "Moved Permanently"
    }
    if status == 302_u16 {
        return "Found"
    }
    if status == 304_u16 {
        return "Not Modified"
    }
    if status == 400_u16 {
        return "Bad Request"
    }
    if status == 401_u16 {
        return "Unauthorized"
    }
    if status == 403_u16 {
        return "Forbidden"
    }
    if status == 404_u16 {
