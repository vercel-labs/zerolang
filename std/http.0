        return null
    }
    buffer[cursor] = 58_u8
    return cursor + 1
}

fn __zero_std_json_write_object_close(buffer: MutSpan<u8>, cursor: usize) -> Maybe<Span<u8>> {
    if cursor >= std.mem.len(buffer) {
        return null
    }
    buffer[cursor] = 125_u8
    return buffer[..cursor + 1]
