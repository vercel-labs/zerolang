fn __zero_std_fmt_i32_sign(buffer: MutSpan<u8>, value: i32) -> Maybe<Span<u8>> {
    if value < 0 {
        return __zero_std_fmt_i32(buffer, value)
    }
    if std.mem.len(buffer) == 0 {
