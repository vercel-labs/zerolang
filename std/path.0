  mut split usize end
  while && (> split 0) (== (__zero_std_path_is_sep path[(- split 1)]) false)
    set split - split 1
  while && (> split root_len) (__zero_std_path_is_sep path[(- split 1)])
    set split - split 1
  ret path[..split]

fn __zero_std_path_extension String path String
  let end usize __zero_std_path_trim_end path
  mut start usize end
  while && (> start 0) (== (__zero_std_path_is_sep path[(- start 1)]) false)
    set start - start 1
  mut dot usize end
  mut scan usize end
  while > scan start
    set scan - scan 1
    if == path[scan] 46_u8
      set dot scan
      set scan start
  if == dot end
    ret path[end..end]
  if == dot start
    ret path[end..end]
  ret path[(+ dot 1)..end]

fn __zero_std_path_copy Maybe<String> buffer MutSpan<u8> source String
  let len usize std.mem.len source
  if > len (std.mem.len buffer)
    ret null
  mut index usize 0
  while < index len
    set buffer[index] source[index]
    set index + index 1
  ret buffer[..len]

fn __zero_std_path_join Maybe<String> buffer MutSpan<u8> left String right String
  mut left_end usize __zero_std_path_trim_end left
  if && (== left_end 0) (&& (> (std.mem.len left) 0) (__zero_std_path_is_sep left[0]))
    set left_end 1
  let left_is_root Bool && (== left_end 1) (__zero_std_path_is_sep left[0])
  let right_is_root Bool && (> (std.mem.len right) 0) (__zero_std_path_is_sep right[0])
  mut right_start usize 0
  while && (< right_start (std.mem.len right)) (__zero_std_path_is_sep right[right_start])
    set right_start + right_start 1
  let right_len usize - (std.mem.len right) right_start
  mut total usize + left_end right_len
  if && (== left_end 0) right_is_root
    set total + total 1
  if && (&& (> left_end 0) (> right_len 0)) (== left_is_root false)
    set total + total 1
  if > total (std.mem.len buffer)
    ret null
  mut out usize 0
  while < out left_end
    if && left_is_root (== out 0)
      set buffer[out] 47_u8
    else
      set buffer[out] left[out]
    set out + out 1
  if && (== left_end 0) right_is_root
    set buffer[out] 47_u8
    set out + out 1
  if && (&& (> left_end 0) (> right_len 0)) (== left_is_root false)
    set buffer[out] 47_u8
    set out + out 1
  mut read usize right_start
  while < read (std.mem.len right)
    set buffer[out] right[read]
    set out + out 1
    set read + read 1
  ret buffer[..out]

fn __zero_std_path_output_ends_parent Bool buffer MutSpan<u8> out usize root_len usize
  if <= out root_len
    ret false
  mut segment_start usize out
  while && (> segment_start root_len) (== (__zero_std_path_is_sep buffer[(- segment_start 1)]) false)
    set segment_start - segment_start 1
  let segment_len usize - out segment_start
  if != segment_len 2
    ret false
  ret && (== buffer[segment_start] 46_u8) (== buffer[(+ segment_start 1)] 46_u8)

fn __zero_std_path_normalize Maybe<String> buffer MutSpan<u8> path String
  mut read usize 0
  mut out usize 0
  mut root_len usize 0
  if && (> (std.mem.len path) 0) (__zero_std_path_is_sep path[0])
    if == (std.mem.len buffer) 0
      ret null
    set buffer[0] 47_u8
    set out 1
    set root_len 1
    set read 1
  while < read (std.mem.len path)
    while && (< read (std.mem.len path)) (__zero_std_path_is_sep path[read])
      set read + read 1
    if < read (std.mem.len path)
      let segment_start usize read
      while && (< read (std.mem.len path)) (== (__zero_std_path_is_sep path[read]) false)
        set read + read 1
      let segment_end usize read
      let segment_len usize - segment_end segment_start
      if && (== segment_len 1) (== path[segment_start] 46_u8)
        set read segment_end
      else
        if && (&& (== segment_len 2) (== path[segment_start] 46_u8)) (== path[(+ segment_start 1)] 46_u8)
          if && (== root_len 1) (== out root_len)
            set read segment_end
          else
            if && (> out root_len) (== (__zero_std_path_output_ends_parent buffer out root_len) false)
              while && (> out root_len) (== (__zero_std_path_is_sep buffer[(- out 1)]) false)
                set out - out 1
              if && (> out root_len) (__zero_std_path_is_sep buffer[(- out 1)])
                set out - out 1
            else
              mut needed usize segment_len
              if > out root_len
                set needed + needed 1
              if > (+ out needed) (std.mem.len buffer)
