pub fun main(world: World) -> Void raises {
    let fs = world.fs()
    let created = std.fs.create(fs, ".zero/bench/zero-owned-file.txt")
    if created.has {
        let mut file: owned<File> = created.value
        if std.fs.writeAll(&mut file, std.mem.span("owned file payload\n")) == false {
            return
        }
    }

    let opened = std.fs.open(fs, ".zero/bench/zero-owned-file.txt")
    if opened.has {
        let mut file: owned<File> = opened.value
        let size = std.fs.fileLen(&mut file)
        if size.has && size.value > 0 {
            check world.out.write("owned file\n")
        }
    }
}
