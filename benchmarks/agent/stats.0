pub fn main Void world World !
  let data [7]i32 [3, -1, 7, 0, 12, -5, 9]
  mut min i32 data[0]
  mut max i32 data[0]
  mut sum i32 0
  mut i i32 0
  while < i 7
    set sum + sum data[i]
    if < data[i] min
      set min data[i]
    if > data[i] max
      set max data[i]
    set i + i 1
  if && (&& (== min -5) (== max 12)) (== sum 25)
    check world.out.write "stats ok\n"
  else
    check world.out.write "stats fail\n"
