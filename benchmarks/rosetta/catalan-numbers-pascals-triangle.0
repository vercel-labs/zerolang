fn catalan(n: u32) -> u32 {
    let value: Maybe<u32> = std.math.binomialU32(2_u32 * n, n)
    if value.has {
        return value.value / (n + 1_u32)
    }
    return 0_u32
}

pub fn main(world: World) -> Void raises {
    if catalan(5_u32) == 42_u32 {
        check world.out.write("catalan ok\n")
    }
}
