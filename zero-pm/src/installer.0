// installer.0 — download, verify checksum, write to cache

use std.mem
use std.str
use std.fs
use std.path
use std.http
use std.net
use std.time
use std.io

use cache

extern c "native/zpm_native.h" as zpm

// Write bytes into the native input buffer starting at `offset`.
fn writeInputAt(offset: usize, data: Span<u8>) -> Void {
    let len: usize = std.mem.len(data)
    var i: usize = 0
    while i < len {
        zpm.write_input((offset + i) as i32, data[i])
        i = i + 1
    }
}

// Verify CRC32 checksum of `data` against `expected` ("crc32:<8hex>").
fn verifyCrc32(data: Span<u8>, expected: Span<u8>) -> Bool {
    let elen: usize = std.mem.len(expected)
    if elen < 14 || !std.str.startsWith(expected, "crc32:") {
        return false
    }
    writeInputAt(0, data)
    let rc: i32 = zpm.crc32_compute(std.mem.len(data) as i32)
    if rc != 8 { return false }
    var out_hex: [8]u8 = [0_u8; 8]
    var i: usize = 0
    while i < 8 {
        out_hex[i] = zpm.read_output(i as i32)
        i = i + 1
    }
    let expected_hex: Span<u8> = expected[6..14]
    let out_span: Span<u8> = out_hex[..]
    return std.mem.eqlBytes(out_span, expected_hex)
}

// Verify SHA-256 checksum of `data` against `expected` ("sha256:<64hex>").
fn verifySha256(data: Span<u8>, expected: Span<u8>) -> Bool {
    let elen: usize = std.mem.len(expected)
    if elen < 71 || !std.str.startsWith(expected, "sha256:") {
        return false
    }
    let hex_part: Span<u8> = expected[7..71]
    writeInputAt(0, data)
    let n: i32 = zpm.sha256_hex(std.mem.len(data) as i32)
    if n != 64 { return false }
    var computed: [64]u8 = [0_u8; 64]
    var j: usize = 0
    while j < 64 {
        computed[j] = zpm.read_output(j as i32)
        j = j + 1
    }
    let computed_span: Span<u8> = computed[..]
    return std.mem.eqlBytes(computed_span, hex_part)
}

// Verify checksum of `data` against `expected`.
// Supports "crc32:<hex>" and "sha256:<hex>" prefixes.
// An empty/unknown expected means "skip verification" (returns true).
pub fn verifyChecksum(data: Span<u8>, expected: Span<u8>) -> Bool {
    let elen: usize = std.mem.len(expected)
    if elen == 0 { return true }
    if std.str.startsWith(expected, "sha256:") {
        return verifySha256(data, expected)
    }
    if std.str.startsWith(expected, "crc32:") {
        return verifyCrc32(data, expected)
    }
    return true
}

// Download `url` using the given HTTP client into `resp_buf`.
// Returns the response body span or null on failure.
fn downloadUrl(client: HttpClient, url: Span<u8>, req_buf: MutSpan<u8>, resp_buf: MutSpan<u8>) -> Maybe<Span<u8>> {
    var line_buf: [320]u8 = [0_u8; 320]
    var cursor: usize = 0
    let c1: Maybe<usize> = std.io.writeSpan(line_buf, cursor, "GET ")
    if !c1.has { return null }
    cursor = c1.value
    let c2: Maybe<usize> = std.io.writeSpan(line_buf, cursor, url)
    if !c2.has { return null }
    cursor = c2.value
    let start_line: Span<u8> = std.io.written(line_buf, cursor)
    let req: Maybe<Span<u8>> = std.http.writeRequest(req_buf, start_line, "")
    if !req.has { return null }
    let result: HttpResult = std.http.fetch(client, req.value, resp_buf, std.time.ms(30000))
    if !std.http.resultOk(result) { return null }
    if std.http.resultStatus(result) != 200_u16 { return null }
    return std.http.responseBody(resp_buf, result)
}

// Extract a tar archive (in `data`) to the cache directory for `name`/`version`.
// The native helper reads the archive from input[0..len] and the destination
// path from input[len..len+dest_len].
fn extractToCache(data: Span<u8>, name: Span<u8>, version: Span<u8>) -> Bool {
    var dir_buf: [384]u8 = [0_u8; 384]
    let dir_m: Maybe<String> = packageDir(dir_buf, name, version)
    if !dir_m.has { return false }
    let dir_bytes: Span<u8> = std.mem.span(dir_m.value)
    let data_len: usize = std.mem.len(data)
    let dlen: usize = std.mem.len(dir_bytes)
    writeInputAt(0, data)
    writeInputAt(data_len, dir_bytes)
    let rc: i32 = zpm.tar_extract(data_len as i32, dlen as i32)
    return rc >= 0
}

// Install a package from `url` into the cache. Verifies `checksum` if non-empty.
// Owns its HTTP client and download buffers to stay within the eight-ABI-slot
// call limit of the direct backend. Returns true on success.
pub fn install(name: Span<u8>, version: Span<u8>, url: Span<u8>, checksum: Span<u8>) -> Bool {
    // Skip if already cached
    if isCached(name, version) {
        return true
    }

    // Download
    let client: HttpClient = std.http.client(std.net.host())
    var req_buf: [512]u8 = [0_u8; 512]
    var resp_buf: [65536]u8 = [0_u8; 65536]
    let body: Maybe<Span<u8>> = downloadUrl(client, url, req_buf, resp_buf)
    if !body.has { return false }

    // Verify checksum
    if !verifyChecksum(body.value, checksum) {
        return false
    }

    // Ensure cache directory exists
    if !ensureDir(name, version) {
        return false
    }

    let data: Span<u8> = body.value
    let dlen: usize = std.mem.len(data)

    // Archives are extracted: gzip magic (1f 8b, covers .tar.gz) or a raw
    // ustar archive ("ust" magic at offset 257). The native helper inflates
    // gzip transparently before extracting.
    let is_gzip: Bool = dlen >= 2 && data[0] == 31_u8 && data[1] == 139_u8
    let is_ustar: Bool = dlen >= 262 && data[257] == 117_u8 && data[258] == 115_u8 && data[259] == 116_u8
    if is_gzip || is_ustar {
        if extractToCache(data, name, version) {
            return markCached(name, version)
        }
        return false
    }

    // Plain file — store directly as <name>.0 in the cache directory
    let fs: Fs = std.fs.host()
    var cache_dir: [384]u8 = [0_u8; 384]
    let dir_m: Maybe<String> = packageDir(cache_dir, name, version)
    if !dir_m.has { return false }
    var name_tmp: [80]u8 = [0_u8; 80]
    let pkg_name_m: Maybe<Span<u8>> = std.str.concat(name_tmp, name, ".0")
    var pkg_filename: Span<u8> = "pkg.0"
    if pkg_name_m.has { pkg_filename = pkg_name_m.value }
    var fp_tmp: [400]u8 = [0_u8; 400]
    let fp_m: Maybe<String> = std.path.join(fp_tmp, dir_m.value, pkg_filename)
    if !fp_m.has { return false }
    if !std.fs.writeFile(fs, fp_m.value, data) {
        return false
    }

    return markCached(name, version)
}
