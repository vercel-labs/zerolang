// cmd_add.0 — `0pm add <name>[@version]` — add a dependency and install

use std.mem
use std.fs
use std.args
use std.io

use jsonwalk
use manifest
use registry
use cmd_install
use output

// Position of '@' in `arg`, or its length when absent.
fn atPos(arg: Span<u8>) -> usize {
    let alen: usize = std.mem.len(arg)
    var i: usize = 0
    while i < alen {
        if arg[i] == 64_u8 {
            return i
        }
        i = i + 1
    }
    return alen
}

// Appends output to `out` and returns its length.
pub fn runAdd(out: MutSpan<u8>) -> usize {
    let fs: Fs = std.fs.host()

    let pkg_arg: Maybe<String> = std.args.get(2)
    if !pkg_arg.has {
        return outError(out, 0, "usage: 0pm add <name>[@version]")
    }
    let arg_span: Span<u8> = std.mem.span(pkg_arg.value)
    let alen: usize = std.mem.len(arg_span)
    let at: usize = atPos(arg_span)
    if at == 0 || at >= 64 {
        return outError(out, 0, "invalid package argument")
    }

    var name_buf: [64]u8 = [0_u8; 64]
    let nlen: usize = std.mem.copy(name_buf, arg_span[..at])
    let name: Span<u8> = name_buf[..nlen]

    var ver_buf: [32]u8 = [0_u8; 32]
    var vlen: usize = 0
    if at < alen {
        vlen = std.mem.copy(ver_buf, arg_span[at + 1..alen])
        if vlen == 0 {
            return outError(out, 0, "invalid package argument")
        }
    }

    var manifest_buf: [4096]u8 = [0_u8; 4096]
    let mlen: usize = readManifestRaw(fs, "zero.json", manifest_buf)
    if mlen == 0 {
        return outError(out, 0, "zero.json not found — run `0pm init` first")
    }
    let manifest_bytes: Span<u8> = manifest_buf[..mlen]

    var registry_buf: [128]u8 = [0_u8; 128]
    let rlen: usize = registryUrlInto(registry_buf)
    let registry_url: Span<u8> = registry_buf[..rlen]

    // Resolve version: if not specified, fetch latest from registry
    if vlen == 0 {
        var body_buf: [4096]u8 = [0_u8; 4096]
        let blen: usize = fetchPackageBody(registry_url, name, body_buf)
        if blen == 0 {
            return outError(out, 0, "package not found in registry")
        }
        vlen = jsonStrField(body_buf[..blen], "latest", ver_buf)
        if vlen == 0 {
            return outError(out, 0, "registry response missing latest version")
        }
    }
    let version: Span<u8> = ver_buf[..vlen]

    // Extract current manifest pieces
    var pkg_name_buf: [64]u8 = [0_u8; 64]
    let pnlen: usize = manifestPkgName(manifest_bytes, pkg_name_buf)
    var pkg_ver_buf: [32]u8 = [0_u8; 32]
    let pvlen: usize = manifestPkgVersion(manifest_bytes, pkg_ver_buf)
    var targets_buf: [512]u8 = [0_u8; 512]
    let tlen: usize = manifestTargetsRaw(manifest_bytes, targets_buf)
    var deps_buf: [2048]u8 = [0_u8; 2048]
    let dlen: usize = manifestDepsRaw(manifest_bytes, deps_buf)

    // Add/update the dep and rewrite zero.json
    var new_deps: [2048]u8 = [0_u8; 2048]
    let ndlen: usize = buildDepsWithAdded(deps_buf[..dlen], name, version, new_deps)
    if ndlen == 0 {
        return outError(out, 0, "failed to add dependency (manifest full?)")
    }
    if !writeManifestZeroJson(pkg_name_buf[..pnlen], pkg_ver_buf[..pvlen], targets_buf[..tlen], new_deps[..ndlen]) {
        return outError(out, 0, "failed to write zero.json")
    }

    // Re-run install; roll the manifest back if installation fails
    var status: [1]u8 = [0_u8; 1]
    var cursor: usize = installAllDeps(out, 0, status)
    if status[0] != 0_u8 {
        if writeManifestZeroJson(pkg_name_buf[..pnlen], pkg_ver_buf[..pvlen], targets_buf[..tlen], deps_buf[..dlen]) {
            return outError(out, cursor, "install failed — zero.json restored")
        }
        return outError(out, cursor, "install failed and zero.json rollback failed")
    }

    var msg_buf: [96]u8 = [0_u8; 96]
    var mc: usize = 0
    let m1: Maybe<usize> = std.io.writeSpan(msg_buf, mc, "added ")
    if m1.has { mc = m1.value }
    let m2: Maybe<usize> = std.io.writeSpan(msg_buf, mc, name)
    if m2.has { mc = m2.value }
    return outLine(out, cursor, std.io.written(msg_buf, mc))
}
