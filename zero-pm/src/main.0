// main.0 — 0pm entry point and sub-command dispatcher

use std.args
use std.mem
use std.io

use types
use output
use cmd_init
use cmd_install
use cmd_add
use cmd_remove
use cmd_list
use cmd_info
use cmd_update

pub fn main(world: World) -> Void raises {
    let sub_m: Maybe<String> = std.args.get(1)
    if !sub_m.has {
        check printUsage(world)
        return
    }
    let sub: Span<u8> = std.mem.span(sub_m.value)

    var result: CmdResult = CmdResult.ok

    if std.mem.eql(sub, "init") {
        result = cmd_init.run(world)
    } else if std.mem.eql(sub, "install") {
        result = cmd_install.run(world)
    } else if std.mem.eql(sub, "add") {
        result = cmd_add.run(world)
    } else if std.mem.eql(sub, "remove") {
        result = cmd_remove.run(world)
    } else if std.mem.eql(sub, "list") {
        result = cmd_list.run(world)
    } else if std.mem.eql(sub, "info") {
        result = cmd_info.run(world)
    } else if std.mem.eql(sub, "update") {
        result = cmd_update.run(world)
    } else if std.mem.eql(sub, "--help") || std.mem.eql(sub, "-h") || std.mem.eql(sub, "help") {
        check printUsage(world)
        return
    } else {
        var msg_buf: [80]u8 = [0_u8; 80]
        var mc: usize = 0
        let a1: Maybe<usize> = std.io.writeSpan(msg_buf, mc, "unknown command: ")
        if a1.has { mc = a1.value }
        let a2: Maybe<usize> = std.io.writeSpan(msg_buf, mc, sub)
        if a2.has { mc = a2.value }
        check output.printError(world, std.io.written(msg_buf, mc))
        check printUsage(world)
        return
    }

    match result {
        CmdResult.ok => {}
        CmdResult.err(msg) => {
            check output.printError(world, std.mem.span(msg))
        }
    }
}

fn printUsage(world: World) -> Void raises {
    check output.printLine(world, "0pm — zerolang package manager v0.1.0")
    check output.printLine(world, "")
    check output.printLine(world, "usage: 0pm <command> [args]")
    check output.printLine(world, "")
    check output.printLine(world, "commands:")
    check output.printLine(world, "  init [name]        create zero.json in current directory")
    check output.printLine(world, "  install            install all dependencies from zero.json")
    check output.printLine(world, "  add <name[@ver]>   add a dependency and install it")
    check output.printLine(world, "  remove <name>      remove a dependency")
    check output.printLine(world, "  list               list installed packages")
    check output.printLine(world, "  info <name>        show package details")
    check output.printLine(world, "  update [name]      update one or all packages to latest")
}
