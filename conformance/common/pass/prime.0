fn isPrime Bool n u32
  if < n 2
    ret false
  mut divisor u32 2
  while <= (* divisor divisor) n
    if == (% n divisor) 0
      ret false
    set divisor + divisor 1
  ret true

pub fn main Void world World !
  if && (&& (isPrime 2) (isPrime 29)) (== (isPrime 30) false)
    check world.out.write "prime ok\n"
