type Gate<static enabledFlag: Bool, static selectedMode: Mode>
  value i32

enum Mode u8
  fast
  tiny

fn readGate<static enabledFlag: Bool, static selectedMode: Mode> i32 gate ref<Gate<enabledFlag,selectedMode>>
  ret gate.value

pub fn main Void world World !
  let gate Gate<true,Mode.fast> Gate . value 1
  let _value readGate<false, Mode.fast> (&gate)
  check world.out.write "bad static bool enum mismatch\n"
