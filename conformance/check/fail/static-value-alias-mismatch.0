alias FourVec FixedVec<u8,4>

type FixedVec<T: Type, static N: usize>
  value T

type Box<T: Type>
  item T

fn first<T: Type> T box ref<Box<T>>
  ret box.item

fn caller FourVec box ref<Box<FixedVec<u8,5>>>
  ret first<FourVec> box

pub fn main Void world World !
  check world.out.write "bad static alias mismatch\n"
