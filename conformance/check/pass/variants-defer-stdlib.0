use std.codec

use std.parse

use std.time

enum Status {
    ready,
    failed,
}

choice Result {
    ok,
    failed: i32,
}

fn cleanup() -> Void {
    return
}

pub fn main(world: World) -> Void raises {
    defer cleanup()
    let status: Status = Status.ready
    let result: Result = Result.ok
    let bytes: Maybe<u32> = std.codec.readU32Le("abcd")
    let digits: usize = std.parse.scanDigits("123abc")
    let duration: Duration = std.time.add(std.time.ms(1), std.time.seconds(1))
    if digits == 3 && bytes.has && bytes.value > 0_u32 && std.time.asMsFloor(duration) > 0 {
        check world.out.write("variants std\n")
    }
}
