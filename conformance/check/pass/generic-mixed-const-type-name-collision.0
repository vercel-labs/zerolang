const Foo usize 3

type Foo
  value i32

type Mixed<T: Type, static N: usize>
  value T
  items [N]i32

fn take<T: Type, static N: usize> T item ref<Mixed<T,N>>
  ret item.value

pub fn main Void
  let mixed Mixed<Foo,Foo> Mixed . value (Foo . value 7) items ([1, 2, 3])
  let value Foo take (&mixed)
  expect (== value.value 7)
