use std.codec
use std.parse
use std.time
use types

fn cleanup Void
  ret

pub fn main Void world World !
  defer cleanup()
  let mode Mode Mode.fast
  let outcome Outcome Outcome.ok
  let bytes std.codec.readU32 "abcd"
  let digits std.parse.scanDigits "123abc"
  let duration std.time.add (std.time.ms 1) (std.time.seconds 1)
  if && (&& (== digits 3) (> bytes 0)) (> (std.time.asMsFloor duration) 0)
    check world.out.write "package pass\n"
