type FixedVec<T: Type, static N: usize>
  len usize
  items [N]T

  fn push Void self mutref<Self> value T ![Full]
    if == self.len N
      raise Full
    set self.items[self.len] value
    set self.len + self.len 1

  fn get Maybe<T> self ref<Self> index usize
    let items [N]T self.items
    ret std.mem.get items index

pub fn main Void !
  mut vec FixedVec<u8,4> FixedVec . len 0 items ([0, 0, 0, 0])
  check FixedVec.push (&mut vec) 7
  let first FixedVec.get (&vec) 0
  expect (&& first.has (== first.value 7))
