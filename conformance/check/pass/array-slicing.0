pub fun main() -> Void {
  let values: [4]i32 = [10, 20, 30, 40]

  let middle: Span<i32> = values[1..3]
  expect(middle[0] == 20)
  expect(middle[1] == 30)

  let tail: Span<i32> = values[2..]
  expect(tail[0] == 30)
  expect(tail[1] == 40)

  let prefix: Span<i32> = values[..2]
  expect(prefix[0] == 10)
  expect(prefix[1] == 20)

  let all: Span<i32> = values[..]
  expect(all[0] == 10 && all[3] == 40)
}
