const Len usize 3

type Len
  value i32

type Bundle<T: Type, static N: usize>
  value T
  items [N]i32

fn payload<T: Type, static N: usize> [N]i32 bundle Bundle<T,N>
  ret bundle.items

pub fn main Void
  let bundle Bundle<Len,Len> Bundle . value (Len . value 7) items ([1, 2, 3])
  let values [Len]i32 payload bundle
  expect (== values[2] 3)
