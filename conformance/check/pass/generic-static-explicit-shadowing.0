const N usize 4

type Helper
  fn needsSame<static M: usize> Void left ref<[M]i32> right ref<[M]i32>

fn needsSame<static M: usize> Void left ref<[M]i32> right ref<[M]i32>

fn caller<static N: usize> Void left ref<[N]i32> right ref<[N]i32>
  needsSame<N> left right
  Helper.needsSame<N> left right

pub fn main Void
  let values [3]i32 [1, 2, 3]
  caller (&values) (&values)
