const Foo: usize = 3

shape Foo {
    value: i32,
}

shape Holder<T> {
    value: T,
}

shape Sized<static N: usize> {
    value: i32,
}

fun take<T>(holder: ref<Holder<T>>) -> T {
    return holder.value
}

fun touchSized<static N: usize>(item: ref<Sized<N>>) -> Void {
}

pub fun main() -> Void {
    let holder: Holder<Foo> = Holder { value: Foo { value: 7 } }
    let value: Foo = take(&holder)
    let sized: Sized<Foo> = Sized { value: 9 }
    touchSized(&sized)
    expect(value.value == 7)
}
