const Foo usize 3

type Foo
  value i32

type Holder<T: Type>
  value T

type Sized<static N: usize>
  value i32

fn take<T: Type> T holder ref<Holder<T>>
  ret holder.value

fn touchSized<static N: usize> Void item ref<Sized<N>>

pub fn main Void
  let holder Holder<Foo> Holder . value (Foo . value 7)
  let value Foo take (&holder)
  let sized Sized<Foo> Sized . value 9
  touchSized (&sized)
  expect (== value.value 7)
