const T usize 3

const N usize 3

type Holder<U: Type>
  value U

type Box<static N: usize>
  value i32

fn unwrap<T: Type> T holder ref<Holder<T>>
  ret holder.value

fn forwardUnwrap<T: Type> T holder ref<Holder<T>>
  ret unwrap holder

fn read<static N: usize> i32 box ref<Box<N>>
  ret box.value

pub fn main Void
  let holder Holder<i32> Holder . value 5
  let value i32 forwardUnwrap (&holder)
  let box Box<4> Box . value 9
  let boxed i32 read (&box)
  expect (&& (== value 5) (== boxed 9))
