type File
  fd i32

fn make owned<File> fd i32
  ret File . fd fd

fn pass owned<File> file owned<File>
  ret file

fn close Void file owned<File>

fn fd i32 file owned<File>
  ret file.fd

pub fn main Void world World !
  mut current owned<File> make 1
  let next owned<File> pass (make 42)
  set current next
  let value fd current
  let cleanup owned<File> make 7
  defer close cleanup
  if == value 42
    check world.out.write "owned transfer ok\n"
  else
    check world.out.write "owned transfer failed\n"
