interface Incrementable<T: Type>
  fn increment i32 self mutref<T>

type Counter
  value i32

  fn increment i32 self mutref<Self>
    set self.value + self.value 1
    ret self.value

fn bump<T: Incrementable<T>> i32 value mutref<T>
  ret T.increment value

pub fn main Void world World !
  mut counter Counter Counter . value 41
  if == (bump<Counter> (&mut counter)) 42
    check world.out.write "static interface mutref ok\n"
  else
    check world.out.write "static interface mutref broke\n"
