fn zeroStdPathNormalize(path: String) -> String {
    return "user helper"
}

pub fn main(world: World) -> Void raises {
    var path_buf: [8]u8 = [0, 0, 0, 0, 0, 0, 0, 0]
    let normalized: Maybe<String> = std.path.normalize(path_buf, "a/")
    if normalized.has {
        if std.mem.eql(normalized.value, "a") && std.mem.eql(zeroStdPathNormalize("x"), "user helper") {
            check world.out.write("std path helper collision ok\n")
        }
    }
}
