type Holder
  value ref<i32>

fn replace Void holder mutref<Holder> next ref<i32>
  set holder.value next

pub fn main Void
  mut old 1
  let next 2
  mut other 3
  mut holder Holder . value (&old)
  let selected &mut holder
  if true
    mut holder Holder . value (&other)
    replace selected (&next)
  set old 4
