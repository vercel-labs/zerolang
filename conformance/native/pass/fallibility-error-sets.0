type DropProbe
  marker MutSpan<u8>

  fn drop Void self mutref<Self>
    set self.marker[0] 1

fn maybe_fail i32 should_fail Bool marker MutSpan<u8> ![BadInput]
  let probe owned<DropProbe> DropProbe . marker marker
  if should_fail
    raise BadInput
  ret 42

fn run Void marker MutSpan<u8> ![BadInput]
  check maybe_fail false marker

pub fn main Void world World !
  mut marker [1]u8 [0]
  check run marker
  if == marker[0] 1_u8
    check world.out.write "fallibility error sets ok\n"
