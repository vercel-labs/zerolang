fn maybeValue Maybe<u8> bytes Span<u8> index usize !
  check std.mem.get bytes index
  ret std.mem.get bytes index

fn privateFail i32 flag Bool !
  if flag
    raise Hidden
  ret 7

fn namedFail i32 flag Bool ![Hidden]
  let value check privateFail flag
  ret value

pub fn main Void world World !
  let bytes [1]u8 [42]
  let found check maybeValue bytes 0
  let fallback rescue (maybeValue bytes 3) err 5_u8
  let recovered rescue (namedFail true) err 9
  if && (&& (== found 42_u8) (== fallback 5_u8)) (== recovered 9)
    check world.out.write "maybe error flow ok\n"
