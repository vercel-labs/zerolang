interface First<T: Type, static N: usize>
  fn first u8 self ref<T>

type Bytes<static N: usize>
  items [N]u8

  fn first u8 self ref<Self>
    ret self.items[0]

fn readFirst<T: First<T,N>, static N: usize> u8 value ref<T>
  ret T.first value

pub fn main Void world World !
  let bytes Bytes<4> Bytes . items ([9, 8, 7, 6])
  if == (readFirst<Bytes<4>, 4> (&bytes)) 9
    check world.out.write "static interface static param ok\n"
