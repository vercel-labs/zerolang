enum Mode {
    left,
    alsoLeft,
}

fun choose(mode: Mode, left: ref<i32>, right: ref<i32>) -> ref<i32> {
    match mode {
        .left {
            return left
        }
        .alsoLeft {
            return left
        }
    }
    return right
}

pub fun main(mode: Mode) -> Void {
    let x = 1
    let mut y = 2
    let current = choose(mode, &x, &y)
    y = 3
}
