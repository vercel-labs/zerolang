fn set Void marker MutSpan<u8> value u8
  set marker[0] value

fn early Void marker MutSpan<u8>
  defer set marker 1
  ret

fn fail i32 marker MutSpan<u8> ![Boom]
  defer set marker 2
  raise Boom

pub fn main Void world World !
  mut early_marker [1]u8 [0]
  mut raise_marker [1]u8 [0]
  mut nested_marker [1]u8 [0]
  early early_marker
  let recovered rescue (fail raise_marker) err 7
  if true
    defer set nested_marker 3
  if && (&& (&& (== early_marker[0] 1) (== raise_marker[0] 2)) (== nested_marker[0] 3)) (== recovered 7)
    check world.out.write "defer return raise nested ok\n"
