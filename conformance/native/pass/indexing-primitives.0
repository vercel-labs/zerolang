type BytesView
  bytes Span<u8>

fn secondByte u8 bytes Span<u8>
  ret bytes[1]

fn thirdArrayByte u8 bytes [4]u8
  ret bytes[2]

pub fn main Void world World !
  let bytes [4]u8 [65, 66, 67, 68]
  let index usize 3
  let view BytesView . bytes (std.mem.span "ABCD")
  if && (&& (&& (== bytes[0] 65) (== (secondByte view.bytes) 66)) (== (thirdArrayByte bytes) 67)) (== view.bytes[index] 68)
    check world.out.write "indexing primitives ok\n"
