type FixedVec<T: Type, static N: usize>
  len usize
  items [N]T

  fn push Void self mutref<Self> value T ![Full]
    if == self.len N
      raise Full
    set self.items[self.len] value
    set self.len + self.len 1

  fn get Maybe<T> self ref<Self> index usize
    ret std.mem.get self.items index

  fn count usize self ref<Self>
    ret self.len

pub fn main Void world World !
  mut vec FixedVec<u8,4> FixedVec . len 0 items ([0, 0, 0, 0])
  check FixedVec.push (&mut vec) 7
  check FixedVec.push (&mut vec) 9
  let first FixedVec.get (&vec) 0
  let missing FixedVec.get (&vec) 8
  if && (&& (&& first.has (== first.value 7)) (== missing.has false)) (== (FixedVec.count (&vec)) 2)
    check world.out.write "generic shape methods ok\n"
