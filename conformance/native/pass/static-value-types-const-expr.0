const cap u8 + 2 2

type Tiny<static N: u8>
  items [N]u8

fn len<static N: u8> usize tiny ref<Tiny<N>>
  ret std.mem.len tiny.items

pub fn main Void world World !
  let tiny Tiny<cap> Tiny . items ([1, 2, 3, 4])
  if == (len<cap> (&tiny)) 4
    check world.out.write "static value types const expr ok\n"
