type FixedVec<T: Type, static N: usize>
  len usize 0
  items [N]T

  fn init Self items [N]T
    ret FixedVec . items items

  fn get Maybe<T> self ref<Self> index usize
    ret std.mem.get self.items index

fn make_vec FixedVec<u8,4>
  ret FixedVec.init ([1, 2, 3, 4])

pub fn main Void world World !
  let vec FixedVec<u8,4> FixedVec.init ([5, 6, 7, 8])
  let from_return make_vec()
  let first vec.get 0
  let returned from_return.get 3
  if && (&& (&& first.has (== first.value 5)) returned.has) (== returned.value 4)
    check world.out.write "generic constructor expected ok\n"
