pub fn main Void world World !
  mut backing [8]u8 [0, 0, 0, 0, 0, 0, 0, 0]
  mut alloc FixedBufAlloc std.mem.fixedBufAlloc backing
  let first std.mem.allocBytes alloc 3
  let second std.mem.allocBytes alloc 5
  let overflow std.mem.allocBytes alloc 1
  let nullAlloc std.mem.nullAlloc()
  let nullBytes std.mem.allocBytes nullAlloc 1
  if && (&& (&& (&& (&& first.has second.has) (== overflow.has false)) (== nullBytes.has false)) (== (std.mem.len first.value) 3)) (== (std.mem.len second.value) 5)
    set first.value[0] 65
    set second.value[4] 90
    if && (== backing[0] 65) (== backing[7] 90)
      check world.out.write "allocator primitives ok\n"
    else
      check world.out.write "allocator primitives wrote wrong bytes\n"
  else
    check world.out.write "allocator primitives failed\n"
