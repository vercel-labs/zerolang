type Point
  x i32
  y i32

type Holder
  point Point

fn read_x i32 point ref<Point>
  ret point.x

fn write_x Void point mutref<Point> value i32
  set point.x value

pub fn main Void world World !
  mut point Point . x 1 y 2
  mut holder Holder . point (Point . x 3 y 4)
  if true
    let shared &point
    if != (read_x shared) 1
      check world.out.write "borrow primitives failed\n"
      ret
  write_x (&mut point) 5
  write_x (&mut holder.point) 9
  if && (== point.x 5) (== holder.point.x 9)
    check world.out.write "borrow primitives ok\n"
  else
    check world.out.write "borrow primitives failed\n"
