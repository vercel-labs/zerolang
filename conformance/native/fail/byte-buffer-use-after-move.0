fn consume Void buf owned<ByteBuf>

pub fn main Void world World !
  mut storage [8]u8 [0, 0, 0, 0, 0, 0, 0, 0]
  mut alloc std.mem.fixedBufAlloc storage
  let maybe std.mem.byteBuf alloc 4
  if maybe.has
    let buf owned<ByteBuf> maybe.value
    consume buf
    let bytes std.mem.bufBytes (&buf)
    check world.out.write "used moved byte buffer"
