interface Readable<T: Type>
  fn read i32 self ref<T>

type Counter
  value i32

  fn read i32 self ref<Self>
    ret self.value

fn readValue<T: Readable<T>> i32 value ref<T>
  ret T.read value

pub fn main Void world World !
  let counter Counter Counter . value 42
  if == (readValue<Counter> (&counter)) 42
    check world.out.write "static interface ok\n"
  else
    check world.out.write "static interface broke\n"
