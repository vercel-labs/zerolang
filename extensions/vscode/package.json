{
  "name": "zero-lang",
  "displayName": "Zero Language",
  "description": "Syntax highlighting for the Zero programming language.",
  "publisher": "zero-lang",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "main": "./extension.mjs",
  "activationEvents": [
    "onLanguage:zero"
  ],
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "install:cursor": "node scripts/install-cursor-extension.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=22",
    "vscode": "^1.100.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0"
  },
  "contributes": {
    "configuration": {
      "title": "Zero",
      "properties": {
        "zero.zeroRoot": {
          "type": "string",
          "default": "",
          "description": "Path to a Zero repository root containing bin/zero and scripts/zls.mts. Set this when the extension is installed outside the monorepo."
        }
      }
    },
    "languages": [
      {
        "id": "zero",
        "aliases": [
          "Zero",
          "zero"
        ],
        "extensions": [
          ".0"
        ],
        "configuration": "./language-configuration/zero.json"
      }
    ],
    "grammars": [
      {
        "language": "zero",
        "scopeName": "source.zero",
        "path": "./syntaxes/zero.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "zero",
        "path": "./snippets/zero.json"
      }
    ]
  }
}
