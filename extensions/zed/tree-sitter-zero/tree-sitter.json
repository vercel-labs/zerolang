{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "zero",
      "camelcase": "Zero",
      "title": "Zero",
      "scope": "source.zero",
      "file-types": ["0"],
      "injection-regex": "^zero$"
    }
  ],
  "metadata": {
    "version": "0.1.1",
    "license": "MIT",
    "description": "Zero grammar for tree-sitter",
    "authors": [
      {
        "name": "Zero contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/zerolang/zero"
    }
  },
  "bindings": {
    "c": true,
    "node": false,
    "python": false,
    "rust": false,
    "go": false,
    "swift": false
  }
}
