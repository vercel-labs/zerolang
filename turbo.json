{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_ASSET_PREFIX",
        "NEXT_BASE_PATH",
        "NEXT_PUBLIC_GITHUB_REPO",
        "NEXT_PUBLIC_SITE_URL"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": []
    }
  }
}
